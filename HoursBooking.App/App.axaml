<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="HoursBooking.App.App"
             xmlns:local="using:HoursBooking.App"
             RequestedThemeVariant="Default">
             <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#ECEEF2"/>
                    <SolidColorBrush x:Key="WindowForegroundBrush" Color="#1C1C1E"/>

                    <SolidColorBrush x:Key="HeaderBackgroundBrush" Color="#F5F5F7"/>
                    <SolidColorBrush x:Key="HeaderForegroundBrush" Color="#1C1C1E"/>
                    <SolidColorBrush x:Key="HeaderSecondaryForegroundBrush" Color="#6E6E73"/>

                    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#FFFFFF"/>
                    <SolidColorBrush x:Key="CardMutedBackgroundBrush" Color="#F5F5F7"/>
                    <SolidColorBrush x:Key="SecondarySurfaceBrush" Color="#EEF0F4"/>

                    <SolidColorBrush x:Key="MetricOneBrush" Color="#F7F9FC"/>
                    <SolidColorBrush x:Key="MetricTwoBrush" Color="#F6FAF7"/>
                    <SolidColorBrush x:Key="MetricThreeBrush" Color="#F7F5FC"/>

                    <SolidColorBrush x:Key="SettingsCardOneBrush" Color="#F8FAFC"/>
                    <SolidColorBrush x:Key="SettingsCardTwoBrush" Color="#F8F7FC"/>
                    <SolidColorBrush x:Key="SettingsCardThreeBrush" Color="#FBF8F3"/>

                    <SolidColorBrush x:Key="SubtleTextBrush" Color="#6E6E73"/>
                    <SolidColorBrush x:Key="HairlineBrush" Color="#DDDDE3"/>
                    <SolidColorBrush x:Key="ControlBackgroundBrush" Color="#FFFFFF"/>
                    <SolidColorBrush x:Key="ControlBorderBrush" Color="#D6D6DC"/>
                    <SolidColorBrush x:Key="ControlForegroundBrush" Color="#1C1C1E"/>
                    <SolidColorBrush x:Key="AccentBrush" Color="#0A84FF"/>
                    <SolidColorBrush x:Key="AccentForegroundBrush" Color="#FFFFFF"/>
                </ResourceDictionary>

                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#1C1C1E"/>
                    <SolidColorBrush x:Key="WindowForegroundBrush" Color="#F5F5F7"/>

                    <SolidColorBrush x:Key="HeaderBackgroundBrush" Color="#2C2C2E"/>
                    <SolidColorBrush x:Key="HeaderForegroundBrush" Color="#F5F5F7"/>
                    <SolidColorBrush x:Key="HeaderSecondaryForegroundBrush" Color="#A1A1A6"/>

                    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#2C2C2E"/>
                    <SolidColorBrush x:Key="CardMutedBackgroundBrush" Color="#242426"/>
                    <SolidColorBrush x:Key="SecondarySurfaceBrush" Color="#36363A"/>

                    <SolidColorBrush x:Key="MetricOneBrush" Color="#303844"/>
                    <SolidColorBrush x:Key="MetricTwoBrush" Color="#2C3830"/>
                    <SolidColorBrush x:Key="MetricThreeBrush" Color="#353142"/>

                    <SolidColorBrush x:Key="SettingsCardOneBrush" Color="#2E3339"/>
                    <SolidColorBrush x:Key="SettingsCardTwoBrush" Color="#312F39"/>
                    <SolidColorBrush x:Key="SettingsCardThreeBrush" Color="#37332D"/>

                    <SolidColorBrush x:Key="SubtleTextBrush" Color="#A1A1A6"/>
                    <SolidColorBrush x:Key="HairlineBrush" Color="#424245"/>
                    <SolidColorBrush x:Key="ControlBackgroundBrush" Color="#3A3A3C"/>
                    <SolidColorBrush x:Key="ControlBorderBrush" Color="#4B4B4F"/>
                    <SolidColorBrush x:Key="ControlForegroundBrush" Color="#F5F5F7"/>
                    <SolidColorBrush x:Key="AccentBrush" Color="#0A84FF"/>
                    <SolidColorBrush x:Key="AccentForegroundBrush" Color="#FFFFFF"/>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </Application.Resources>
  
    <Application.Styles>
        <FluentTheme />
        <Style Selector="Window">
            <Setter Property="Background" Value="{DynamicResource WindowBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource WindowForegroundBrush}"/>
        </Style>
        <Style Selector="Button">
            <Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource ControlForegroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ControlBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="13,8"/>
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="Button:pointerover">
            <Setter Property="Background" Value="{DynamicResource SecondarySurfaceBrush}"/>
        </Style>
        <Style Selector="Button:pressed">
            <Setter Property="Background" Value="{DynamicResource HairlineBrush}"/>
        </Style>
        <Style Selector="Button.primaryAction">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentForegroundBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style Selector="Button.primaryAction:pointerover">
            <Setter Property="Opacity" Value="0.92"/>
        </Style>
        <Style Selector="Button.primaryAction:pressed">
            <Setter Property="Opacity" Value="0.82"/>
        </Style>
        <Style Selector="Button.secondaryAction">
            <Setter Property="Background" Value="{DynamicResource SecondarySurfaceBrush}"/>
        </Style>
        <Style Selector="Button.ghostAction">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="Button.iconRound">
            <Setter Property="Width" Value="52"/>
            <Setter Property="Height" Value="52"/>
            <Setter Property="MinHeight" Value="52"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="CornerRadius" Value="26"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style Selector="ComboBox">
            <Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource ControlForegroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ControlBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style Selector="NumericUpDown">
            <Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource ControlForegroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ControlBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style Selector="TimePicker">
            <Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource ControlForegroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ControlBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style Selector="TextBox">
            <Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource ControlForegroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ControlBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style Selector="TabControl">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="TabItem">
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource SubtleTextBrush}"/>
        </Style>
        <Style Selector="TabItem:pointerover">
            <Setter Property="Background" Value="{DynamicResource SecondarySurfaceBrush}"/>
        </Style>
        <Style Selector="TabItem:selected">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource WindowForegroundBrush}"/>
        </Style>
    </Application.Styles>
</Application>