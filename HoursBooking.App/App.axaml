<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="HoursBooking.App.App"
             xmlns:local="using:HoursBooking.App"
             RequestedThemeVariant="Default">
             <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#EFF2F6"/>
                    <SolidColorBrush x:Key="WindowForegroundBrush" Color="#18212B"/>

                    <SolidColorBrush x:Key="HeaderBackgroundBrush" Color="#F8FAFD"/>
                    <SolidColorBrush x:Key="HeaderForegroundBrush" Color="#111827"/>
                    <SolidColorBrush x:Key="HeaderSecondaryForegroundBrush" Color="#667281"/>

                    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#FCFDFF"/>
                    <SolidColorBrush x:Key="CardMutedBackgroundBrush" Color="#F7F9FC"/>
                    <SolidColorBrush x:Key="SecondarySurfaceBrush" Color="#F2F5F9"/>

                    <SolidColorBrush x:Key="MetricOneBrush" Color="#EAF2FF"/>
                    <SolidColorBrush x:Key="MetricTwoBrush" Color="#EDF8F0"/>
                    <SolidColorBrush x:Key="MetricThreeBrush" Color="#F4F1FF"/>

                    <SolidColorBrush x:Key="SettingsCardOneBrush" Color="#F2F6FB"/>
                    <SolidColorBrush x:Key="SettingsCardTwoBrush" Color="#F5F2FB"/>
                    <SolidColorBrush x:Key="SettingsCardThreeBrush" Color="#FBF6EF"/>

                    <SolidColorBrush x:Key="SubtleTextBrush" Color="#5D6877"/>
                    <SolidColorBrush x:Key="HairlineBrush" Color="#D7DEE7"/>
                    <SolidColorBrush x:Key="ControlBackgroundBrush" Color="#FFFFFF"/>
                    <SolidColorBrush x:Key="ControlBorderBrush" Color="#D9E0E8"/>
                    <SolidColorBrush x:Key="ControlForegroundBrush" Color="#18212B"/>
                    <SolidColorBrush x:Key="AccentBrush" Color="#0A84FF"/>
                    <SolidColorBrush x:Key="AccentForegroundBrush" Color="#FFFFFF"/>
                </ResourceDictionary>

                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#17191D"/>
                    <SolidColorBrush x:Key="WindowForegroundBrush" Color="#F5F7FA"/>

                    <SolidColorBrush x:Key="HeaderBackgroundBrush" Color="#23262C"/>
                    <SolidColorBrush x:Key="HeaderForegroundBrush" Color="#F5F7FA"/>
                    <SolidColorBrush x:Key="HeaderSecondaryForegroundBrush" Color="#AAB4C0"/>

                    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#22252B"/>
                    <SolidColorBrush x:Key="CardMutedBackgroundBrush" Color="#272B31"/>
                    <SolidColorBrush x:Key="SecondarySurfaceBrush" Color="#2C3138"/>

                    <SolidColorBrush x:Key="MetricOneBrush" Color="#243146"/>
                    <SolidColorBrush x:Key="MetricTwoBrush" Color="#21372B"/>
                    <SolidColorBrush x:Key="MetricThreeBrush" Color="#31294A"/>

                    <SolidColorBrush x:Key="SettingsCardOneBrush" Color="#242E39"/>
                    <SolidColorBrush x:Key="SettingsCardTwoBrush" Color="#2B263A"/>
                    <SolidColorBrush x:Key="SettingsCardThreeBrush" Color="#352D25"/>

                    <SolidColorBrush x:Key="SubtleTextBrush" Color="#AAB4C0"/>
                    <SolidColorBrush x:Key="HairlineBrush" Color="#3A4049"/>
                    <SolidColorBrush x:Key="ControlBackgroundBrush" Color="#2B2F36"/>
                    <SolidColorBrush x:Key="ControlBorderBrush" Color="#3D444E"/>
                    <SolidColorBrush x:Key="ControlForegroundBrush" Color="#F5F7FA"/>
                    <SolidColorBrush x:Key="AccentBrush" Color="#0A84FF"/>
                    <SolidColorBrush x:Key="AccentForegroundBrush" Color="#FFFFFF"/>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </Application.Resources>
  
    <Application.Styles>
        <FluentTheme />
        <Style Selector="Window">
            <Setter Property="Background" Value="{DynamicResource WindowBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource WindowForegroundBrush}"/>
        </Style>
        <Style Selector="Button">
            <Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource ControlForegroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ControlBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="Button:pointerover">
            <Setter Property="Background" Value="{DynamicResource SecondarySurfaceBrush}"/>
        </Style>
        <Style Selector="Button:pressed">
            <Setter Property="Background" Value="{DynamicResource HairlineBrush}"/>
        </Style>
        <Style Selector="ComboBox">
            <Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource ControlForegroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ControlBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style Selector="NumericUpDown">
            <Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource ControlForegroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ControlBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style Selector="TimePicker">
            <Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource ControlForegroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ControlBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style Selector="TextBox">
            <Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource ControlForegroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ControlBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style Selector="TabControl">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="TabItem">
            <Setter Property="Padding" Value="16,9"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource SubtleTextBrush}"/>
        </Style>
        <Style Selector="TabItem:selected">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource WindowForegroundBrush}"/>
        </Style>
    </Application.Styles>
</Application>