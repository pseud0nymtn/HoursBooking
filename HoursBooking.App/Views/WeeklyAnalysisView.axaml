<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:HoursBooking.App.ViewModels"
             mc:Ignorable="d"
             x:Class="HoursBooking.App.Views.WeeklyAnalysisView"
             x:DataType="vm:WeeklyAnalysisViewModel">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="14" Margin="0,10,0,0">
            <Border CornerRadius="20"
                    Padding="16"
                    Background="{DynamicResource CardBackgroundBrush}"
                    BorderBrush="{DynamicResource HairlineBrush}"
                    BorderThickness="1"
                    BoxShadow="0 10 24 0 #12000000">
                <StackPanel Spacing="12">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                        <Button Grid.Column="0"
                                Content="{Binding PreviousWeekText}"
                                Classes="ghostAction"
                                Command="{Binding ShowPreviousWeekCommand}"/>

                        <StackPanel Grid.Column="1" Spacing="2" HorizontalAlignment="Center">
                            <TextBlock Text="{Binding WeeklyMetricsTitle}"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center"
                                       Foreground="{DynamicResource WindowForegroundBrush}"/>
                            <TextBlock Text="{Binding SelectedWeekRangeText}"
                                       FontSize="12"
                                       HorizontalAlignment="Center"
                                       Foreground="{DynamicResource SubtleTextBrush}"/>
                        </StackPanel>

                        <Button Grid.Column="2"
                                Content="{Binding NextWeekText}"
                                Classes="ghostAction"
                                Command="{Binding ShowNextWeekCommand}"/>
                    </Grid>

                    <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="10">
                        <Border Grid.Column="0"
                                CornerRadius="14"
                                Padding="10"
                                Background="{DynamicResource MetricOneBrush}"
                                BorderBrush="{DynamicResource HairlineBrush}"
                                BorderThickness="1">
                            <StackPanel Spacing="2">
                                <TextBlock Text="{Binding WeeklyGrossLabel}" FontSize="11" Foreground="{DynamicResource SubtleTextBrush}" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding WeeklyGrossWorkedText}" FontSize="18" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1"
                                CornerRadius="14"
                                Padding="10"
                                Background="{DynamicResource MetricThreeBrush}"
                                BorderBrush="{DynamicResource HairlineBrush}"
                                BorderThickness="1">
                            <StackPanel Spacing="2">
                                <TextBlock Text="{Binding WeeklyNetLabel}" FontSize="11" Foreground="{DynamicResource SubtleTextBrush}" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding WeeklyNetWorkedText}" FontSize="18" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2"
                                CornerRadius="14"
                                Padding="10"
                                Background="{DynamicResource MetricTwoBrush}"
                                BorderBrush="{DynamicResource HairlineBrush}"
                                BorderThickness="1">
                            <StackPanel Spacing="2">
                                <TextBlock Text="{Binding WeeklyDesiredLabel}" FontSize="11" Foreground="{DynamicResource SubtleTextBrush}" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding WeeklyDesiredText}" FontSize="18" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="3"
                                CornerRadius="14"
                                Padding="10"
                                Background="{DynamicResource SecondarySurfaceBrush}"
                                BorderBrush="{DynamicResource HairlineBrush}"
                                BorderThickness="1">
                            <StackPanel Spacing="2">
                                <TextBlock Text="{Binding WeeklyDifferenceLabel}" FontSize="11" Foreground="{DynamicResource SubtleTextBrush}" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding WeeklyDifferenceStatus}" FontSize="18" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>

            <Border CornerRadius="20"
                    Padding="16"
                    Background="{DynamicResource SecondarySurfaceBrush}"
                    BorderBrush="{DynamicResource HairlineBrush}"
                    BorderThickness="1"
                    BoxShadow="0 10 24 0 #12000000">
                <StackPanel Spacing="12">
                    <TextBlock Text="{Binding WeeklyAnalysisTitle}"
                               FontSize="16"
                               FontWeight="SemiBold"/>

                    <Grid ColumnDefinitions="2.2*,1.2*" ColumnSpacing="14">
                        <Border Grid.Column="0"
                                CornerRadius="14"
                                Padding="12"
                                Background="{DynamicResource CardBackgroundBrush}"
                                BorderBrush="{DynamicResource HairlineBrush}"
                                BorderThickness="1">
                            <StackPanel Spacing="8">
                                <TextBlock Text="{Binding WeeklyChartTitle}"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource SubtleTextBrush}"/>

                                <ItemsControl ItemsSource="{Binding WeeklyDayAnalysisItems}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:WeeklyDayAnalysisItemViewModel">
                                            <Grid ColumnDefinitions="52,*,Auto" ColumnSpacing="8" Margin="0,2,0,2">
                                                <StackPanel Grid.Column="0" Spacing="1">
                                                    <TextBlock Text="{Binding DayLabel}" FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding DateLabel}" FontSize="11" Foreground="{DynamicResource SubtleTextBrush}"/>
                                                </StackPanel>

                                                <StackPanel Grid.Column="1" Spacing="2">
                                                    <ProgressBar Minimum="0"
                                                                 Maximum="{Binding TargetMinutes}"
                                                                 Value="{Binding NetMinutes}"
                                                                 Height="9"/>
                                                    <TextBlock Text="{Binding NetWorkedText}"
                                                               FontSize="11"
                                                               Foreground="{DynamicResource SubtleTextBrush}"/>
                                                </StackPanel>

                                                <TextBlock Grid.Column="2"
                                                           VerticalAlignment="Center"
                                                           Text="{Binding DifferenceText}"
                                                           FontWeight="SemiBold"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <TextBlock Text="{Binding WeeklyNoDataText}"
                                           FontSize="12"
                                           Foreground="{DynamicResource SubtleTextBrush}"
                                           IsVisible="{Binding ShowWeeklyNoData}"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1"
                                CornerRadius="14"
                                Padding="12"
                                Background="{DynamicResource CardBackgroundBrush}"
                                BorderBrush="{DynamicResource HairlineBrush}"
                                BorderThickness="1">
                            <StackPanel Spacing="8">
                                <TextBlock Text="{Binding WeeklyInsightsTitle}"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource SubtleTextBrush}"/>

                                <StackPanel Spacing="3">
                                    <TextBlock Text="{Binding WeeklyAveragePerWorkedDayLabel}" FontSize="12" Foreground="{DynamicResource SubtleTextBrush}"/>
                                    <TextBlock Text="{Binding WeeklyAveragePerWorkedDayText}" FontSize="18" FontWeight="Bold"/>
                                </StackPanel>

                                <StackPanel Spacing="3">
                                    <TextBlock Text="{Binding WeeklyBestDayLabel}" FontSize="12" Foreground="{DynamicResource SubtleTextBrush}"/>
                                    <TextBlock Text="{Binding WeeklyBestDayText}" FontSize="14" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                </StackPanel>

                                <StackPanel Spacing="3">
                                    <TextBlock Text="{Binding WeeklyTargetReachedDaysLabel}" FontSize="12" Foreground="{DynamicResource SubtleTextBrush}"/>
                                    <TextBlock Text="{Binding WeeklyTargetReachedDaysText}" FontSize="16" FontWeight="SemiBold"/>
                                </StackPanel>

                                <StackPanel Spacing="3">
                                    <TextBlock Text="{Binding WeeklyLongestBreakLabel}" FontSize="12" Foreground="{DynamicResource SubtleTextBrush}"/>
                                    <TextBlock Text="{Binding WeeklyLongestBreakText}" FontSize="16" FontWeight="SemiBold"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Border CornerRadius="14"
                            Padding="12"
                            Background="{DynamicResource CardBackgroundBrush}"
                            BorderBrush="{DynamicResource HairlineBrush}"
                            BorderThickness="1">
                        <StackPanel Spacing="8">
                            <TextBlock Text="{Binding WeeklyTrendTitle}"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource SubtleTextBrush}"/>

                            <Grid>
                                <Border Height="120"
                                        Background="{DynamicResource SecondarySurfaceBrush}"
                                        CornerRadius="10"
                                        BorderBrush="{DynamicResource HairlineBrush}"
                                        BorderThickness="1">
                                    <Canvas Width="480" Height="120" Margin="8,0">
                                        <Polyline Points="{Binding WeeklyTrendPolylinePoints}"
                                                  Stroke="{DynamicResource HeaderForegroundBrush}"
                                                  StrokeThickness="2"/>
                                    </Canvas>
                                </Border>
                            </Grid>

                            <ItemsControl ItemsSource="{Binding WeeklyTrendPoints}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" Spacing="8"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:WeeklyTrendPointItemViewModel">
                                        <Border CornerRadius="8"
                                                Padding="6"
                                                Width="68"
                                                Background="{DynamicResource SecondarySurfaceBrush}">
                                            <StackPanel Spacing="1">
                                                <TextBlock Text="{Binding WeekLabel}" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                                <TextBlock Text="{Binding RangeLabel}" FontSize="10" Foreground="{DynamicResource SubtleTextBrush}" HorizontalAlignment="Center"/>
                                                <TextBlock Text="{Binding NetWorkedText}" FontSize="11" HorizontalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
