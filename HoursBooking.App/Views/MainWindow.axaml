<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:HoursBooking.App.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d" d:DesignWidth="1180" d:DesignHeight="760"
        x:Class="HoursBooking.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
    Title="Arbeitszeit buchen"
    Background="{DynamicResource WindowBackgroundBrush}"
    Foreground="{DynamicResource WindowForegroundBrush}">

    <Design.DataContext>
        <!-- This only sets the DataContext for the previewer in an IDE,
             to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                  VerticalScrollBarVisibility="Auto">
        <Grid RowDefinitions="Auto,*" Margin="20">
        <Border Grid.Row="0"
                CornerRadius="14"
                Padding="18"
                Margin="0,0,0,16"
            Background="{DynamicResource HeaderBackgroundBrush}">
            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" RowSpacing="8">
                <TextBlock Grid.Row="0"
                           Grid.Column="0"
                           Text="Arbeitszeitbuchung"
                           FontSize="26"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource HeaderForegroundBrush}"/>
                <TextBlock Grid.Row="1"
                           Grid.Column="0"
                           Text="{Binding CurrentDayLabel}"
                           FontSize="15"
                           Foreground="{DynamicResource HeaderSecondaryForegroundBrush}"/>

                <StackPanel Grid.Row="0"
                            Grid.RowSpan="2"
                            Grid.Column="1"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Orientation="Horizontal"
                            Spacing="14">
                    <TextBlock Text="{Binding CurrentTimeLabel}"
                               FontSize="26"
                               FontWeight="Bold"
                               Foreground="{DynamicResource HeaderForegroundBrush}"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" ColumnDefinitions="2.2*,1.3*" ColumnSpacing="16">
            <StackPanel Grid.Column="0" Spacing="16">
                <Border CornerRadius="12" Padding="16" Background="{DynamicResource CardBackgroundBrush}">
                    <StackPanel Spacing="14">
                        <TextBlock Text="Buchung"
                                   FontSize="20"
                                   FontWeight="SemiBold"/>

                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Button Name="ClockInButton"
                                    Content="Einstempeln"
                                    Width="150"
                                    Height="40"
                                    Command="{Binding ClockInCommand}"/>
                            <Button Name="ClockOutButton"
                                    Content="Ausstempeln"
                                    Width="150"
                                    Height="40"
                                    Command="{Binding ClockOutCommand}"/>
                        </StackPanel>

                        <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10">
                            <Border Grid.Column="0" CornerRadius="10" Padding="12" Background="{DynamicResource MetricOneBrush}">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Brutto" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding GrossWorkedText}" FontSize="25" FontWeight="Bold"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1" CornerRadius="10" Padding="12" Background="{DynamicResource MetricTwoBrush}">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Pause (Abzug)" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding DeductedBreakText}" FontSize="25" FontWeight="Bold"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2" CornerRadius="10" Padding="12" Background="{DynamicResource MetricThreeBrush}">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Netto" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding NetWorkedText}" FontSize="25" FontWeight="Bold"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Border CornerRadius="10"
                                Padding="12"
                                Background="{Binding AlertBackground}">
                            <StackPanel Spacing="6">
                                <TextBlock Text="{Binding AlertMessage}"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="{Binding AlertForeground}"/>
                                <TextBlock Text="{Binding DesiredEndTimeText}"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="{Binding AlertForeground}"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <Border CornerRadius="12" Padding="16" Background="{DynamicResource CardMutedBackgroundBrush}">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Arbeitsabschnitte"
                                   FontSize="20"
                                   FontWeight="SemiBold"/>
                        <Grid ColumnDefinitions="*,*,*,Auto" ColumnSpacing="8" Margin="0,0,0,4">
                            <TextBlock Grid.Column="0" Text="Start" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="1" Text="Ende" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="2" Text="Dauer" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="3" Text="Aktion" FontWeight="SemiBold"/>
                        </Grid>
                        <ItemsControl ItemsSource="{Binding Segments}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:WorkSegmentItemViewModel">
                                    <Grid ColumnDefinitions="*,*,*,Auto" ColumnSpacing="8" Margin="0,2,0,2">
                                        <TextBlock Grid.Column="0" Text="{Binding Start}"/>
                                        <TextBlock Grid.Column="1" Text="{Binding End}"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Duration}"/>
                                        <Button Grid.Column="3"
                                                Content="Bearbeiten"
                                            Command="{ReflectionBinding DataContext.EditSegmentCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding .}"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Border CornerRadius="10" Padding="12" Background="{DynamicResource CardBackgroundBrush}">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Arbeitsabschnitt nachbearbeiten"
                                           FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding SegmentEditMessage}"
                                           Foreground="{DynamicResource SubtleTextBrush}"
                                           TextWrapping="Wrap"/>
                                <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                                    <StackPanel Grid.Column="0" Spacing="4">
                                        <TextBlock Text="Start (HH:mm)"/>
                                        <TextBox Text="{Binding SelectedSegmentStartText}" Watermark="08:15"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Spacing="4">
                                        <TextBlock Text="Ende (HH:mm, leer = laufend)"/>
                                        <TextBox Text="{Binding SelectedSegmentEndText}" Watermark="16:45"/>
                                    </StackPanel>
                                </Grid>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button Content="Uebernehmen"
                                            Command="{Binding ApplySegmentEditCommand}"/>
                                    <Button Content="Abbrechen"
                                            Command="{Binding CancelSegmentEditCommand}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </StackPanel>

            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="16">
                    <Border CornerRadius="12" Padding="16" Background="{DynamicResource SettingsCardOneBrush}">
                        <StackPanel Spacing="10">
                            <TextBlock Text="Anzeige"
                                       FontSize="20"
                                       FontWeight="SemiBold"/>
                            <TextBlock Text="Theme"/>
                            <ComboBox Name="ThemeComboBox"
                                      ItemsSource="{Binding ThemeModes}"
                                      SelectedItem="{Binding SelectedThemeMode}" />
                        </StackPanel>
                    </Border>

                    <Border CornerRadius="12" Padding="16" Background="{DynamicResource SettingsCardTwoBrush}">
                        <StackPanel Spacing="10">
                            <TextBlock Text="Warnstufen"
                                       FontSize="20"
                                       FontWeight="SemiBold"/>
                            <TextBlock Text="Maximale Arbeitszeit Netto (Stunden)"/>
                            <NumericUpDown Minimum="0.1" Maximum="24" Increment="0.25" Value="{Binding MaxWorkHours}"/>

                            <TextBlock Text="Wunscharbeitszeit Netto (Stunden)"/>
                            <NumericUpDown Minimum="0" Maximum="24" Increment="0.25" Value="{Binding DesiredWorkHours}"/>

                            <CheckBox Content="Ausgestempelte Zeiten auf Pausenpflicht anrechnen"
                                      IsChecked="{Binding CountStampedOutTimeAsBreak}"/>

                            <TextBlock Text="Info-Schwelle (Minuten Restzeit)"/>
                            <NumericUpDown Minimum="0" Maximum="600" Increment="5" Value="{Binding InfoThresholdMinutes}"/>

                            <TextBlock Text="Warning-Schwelle (Minuten Restzeit)"/>
                            <NumericUpDown Minimum="0" Maximum="600" Increment="5" Value="{Binding WarningThresholdMinutes}"/>

                            <TextBlock Text="Error-Schwelle (Minuten Restzeit)"/>
                            <NumericUpDown Minimum="0" Maximum="600" Increment="5" Value="{Binding ErrorThresholdMinutes}"/>
                        </StackPanel>
                    </Border>

                    <Border CornerRadius="12" Padding="16" Background="{DynamicResource SettingsCardThreeBrush}">
                        <StackPanel Spacing="10">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Grid.Column="0"
                                           Text="Pausenregeln"
                                           FontSize="20"
                                           FontWeight="SemiBold"/>
                                <Button Grid.Column="1"
                                        Content="+ Regel"
                                        Command="{Binding AddBreakRuleCommand}" />
                            </Grid>

                            <ItemsControl ItemsSource="{Binding BreakRules}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:BreakRuleViewModel">
                                        <Grid ColumnDefinitions="1.1*,1.1*,Auto" ColumnSpacing="8" Margin="0,2,0,2">
                                            <NumericUpDown Grid.Column="0"
                                                           Minimum="0"
                                                           Maximum="24"
                                                           Increment="0.25"
                                                           Value="{Binding MinWorkedHours}"/>
                                            <NumericUpDown Grid.Column="1"
                                                           Minimum="0"
                                                           Maximum="8"
                                                           Increment="0.25"
                                                           Value="{Binding DeductedBreakHours}"/>
                                            <Button Grid.Column="2"
                                                    Content="Entfernen"
                                                    Command="{ReflectionBinding DataContext.RemoveBreakRuleCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding .}"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock Text="Format: Wenn Arbeitszeit >= MinWorkedHours, dann DeductedBreakHours abziehen."
                                       FontSize="12"
                                       Foreground="{DynamicResource SubtleTextBrush}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <Button Content="Einstellungen jetzt speichern"
                            HorizontalAlignment="Right"
                            Command="{Binding SaveSettingsCommand}"/>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
    </ScrollViewer>

</Window>
