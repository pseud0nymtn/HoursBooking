<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:HoursBooking.App.ViewModels"
    xmlns:views="using:HoursBooking.App.Views"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d" d:DesignWidth="1180" d:DesignHeight="760"
        x:Class="HoursBooking.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/hoursbooking-icon-dark.ico"
    Title="{Binding WindowTitle}"
    Background="{DynamicResource WindowBackgroundBrush}"
    Foreground="{DynamicResource WindowForegroundBrush}">

    <Design.DataContext>
        <!-- This only sets the DataContext for the previewer in an IDE,
             to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">
        <Grid RowDefinitions="Auto,*" RowSpacing="8" Margin="16">
        <Border Grid.Row="0"
                CornerRadius="18"
                Padding="14"
                Margin="0,0,0,12"
            Background="{DynamicResource HeaderBackgroundBrush}"
                BorderBrush="{DynamicResource HairlineBrush}"
                BorderThickness="1"
                BoxShadow="0 10 24 0 #10000000"
                IsVisible="{Binding ShowWindowHeader}">
            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" RowSpacing="8">
                <TextBlock Grid.Row="0"
                           Grid.Column="0"
                           Text="{Binding HeaderTitle}"
                           FontSize="24"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource HeaderForegroundBrush}"/>
                <TextBlock Grid.Row="1"
                           Grid.Column="0"
                           Text="{Binding CurrentDayLabel}"
                           IsVisible="{Binding ShowHeaderDate}"
                           FontSize="15"
                           Foreground="{DynamicResource HeaderSecondaryForegroundBrush}"/>

                <Border Grid.Row="0"
                        Grid.RowSpan="2"
                        Grid.Column="1"
                        IsVisible="{Binding ShowHeaderClock}"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Padding="12,8"
                        CornerRadius="14"
                        Background="{DynamicResource SecondarySurfaceBrush}"
                        BorderBrush="{DynamicResource HairlineBrush}"
                        BorderThickness="1">
                    <TextBlock Text="{Binding CurrentTimeLabel}"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="{DynamicResource HeaderForegroundBrush}"/>
                </Border>
            </Grid>
        </Border>

        <TabControl x:Name="MainTabs" Grid.Row="1">
            <TabItem Header="{Binding Booking.Owner.BookingTabHeader}">
                <views:BookingView DataContext="{Binding Booking}"/>
            </TabItem>

            <TabItem Header="{Binding WeeklyAnalysis.TabHeader}">
                <views:WeeklyAnalysisView DataContext="{Binding WeeklyAnalysis}"/>
            </TabItem>

            <TabItem Header="{Binding Settings.Owner.SettingsTabHeader}" IsVisible="{Binding ShowSettingsTab}">
                <views:SettingsView DataContext="{Binding Settings}"/>
            </TabItem>
        </TabControl>
    </Grid>
    </ScrollViewer>

</Window>
