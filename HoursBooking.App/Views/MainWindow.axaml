<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:HoursBooking.App.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d" d:DesignWidth="1180" d:DesignHeight="760"
        x:Class="HoursBooking.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
    Title="Arbeitszeit buchen"
    Background="{DynamicResource WindowBackgroundBrush}"
    Foreground="{DynamicResource WindowForegroundBrush}">

    <Design.DataContext>
        <!-- This only sets the DataContext for the previewer in an IDE,
             to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">
        <Grid RowDefinitions="Auto,*" RowSpacing="8" Margin="16">
        <Border Grid.Row="0"
                CornerRadius="18"
                Padding="14"
                Margin="0,0,0,12"
            Background="{DynamicResource HeaderBackgroundBrush}"
                BorderBrush="{DynamicResource HairlineBrush}"
                BorderThickness="1"
                BoxShadow="0 10 24 0 #10000000"
                IsVisible="{Binding ShowWindowHeader}">
            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" RowSpacing="8">
                <TextBlock Grid.Row="0"
                           Grid.Column="0"
                           Text="Arbeitszeitbuchung"
                           FontSize="24"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource HeaderForegroundBrush}"/>
                <TextBlock Grid.Row="1"
                           Grid.Column="0"
                           Text="{Binding CurrentDayLabel}"
                           IsVisible="{Binding ShowHeaderDate}"
                           FontSize="15"
                           Foreground="{DynamicResource HeaderSecondaryForegroundBrush}"/>

                <Border Grid.Row="0"
                        Grid.RowSpan="2"
                        Grid.Column="1"
                        IsVisible="{Binding ShowHeaderClock}"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Padding="12,8"
                        CornerRadius="14"
                        Background="{DynamicResource SecondarySurfaceBrush}"
                        BorderBrush="{DynamicResource HairlineBrush}"
                        BorderThickness="1">
                    <TextBlock Text="{Binding CurrentTimeLabel}"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="{DynamicResource HeaderForegroundBrush}"/>
                </Border>
            </Grid>
        </Border>

        <TabControl x:Name="MainTabs" Grid.Row="1">
            <TabItem Header="Buchung">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="14" Margin="0,10,0,0">
                        <Border CornerRadius="28"
                                Padding="18"
                                Background="{DynamicResource CardBackgroundBrush}"
                                BorderBrush="{DynamicResource HairlineBrush}"
                                BorderThickness="1"
                                BoxShadow="0 14 36 0 #12000000"
                                IsVisible="{Binding ShowMinimalClockMode}">
                            <StackPanel Spacing="14">
                                <TextBlock Text="Stempeluhr"
                                           FontSize="20"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center"/>

                                <Border CornerRadius="20"
                                        Padding="14"
                                        Background="{DynamicResource SecondarySurfaceBrush}">
                                    <StackPanel Spacing="10">
                                        <Border HorizontalAlignment="Center"
                                                Padding="10,5"
                                                CornerRadius="999"
                                                Background="{DynamicResource CardBackgroundBrush}"
                                                BorderBrush="{DynamicResource HairlineBrush}"
                                                BorderThickness="1">
                                            <TextBlock Text="Letzter Start"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource SubtleTextBrush}"/>
                                        </Border>
                                        <StackPanel Spacing="0" HorizontalAlignment="Center">
                                            <TextBlock Text="{Binding ActiveClockInText}"
                                                       FontSize="30"
                                                       FontWeight="Bold"
                                                       HorizontalAlignment="Center"/>
                                            <TextBlock Text="Netto heute"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource SubtleTextBrush}"
                                                       HorizontalAlignment="Center"/>
                                        </StackPanel>

                                        <Border CornerRadius="18"
                                                Padding="14"
                                                Background="{DynamicResource MetricThreeBrush}"
                                                BorderBrush="{DynamicResource HairlineBrush}"
                                                BorderThickness="1">
                                            <StackPanel Spacing="0" HorizontalAlignment="Center">
                                                <TextBlock Text="{Binding NetWorkedText}"
                                                           FontSize="34"
                                                           FontWeight="Bold"
                                                           HorizontalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Border>

                                <StackPanel Spacing="8">
                                    <Button Content="Einstempeln"
                                            Height="42"
                                            Background="{DynamicResource AccentBrush}"
                                            Foreground="{DynamicResource AccentForegroundBrush}"
                                            BorderThickness="0"
                                            Command="{Binding ClockInCommand}"/>
                                    <Button Content="Ausstempeln"
                                            Height="42"
                                            Background="{DynamicResource SecondarySurfaceBrush}"
                                            Command="{Binding ClockOutCommand}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border CornerRadius="24"
                                Padding="18"
                                Background="{DynamicResource CardBackgroundBrush}"
                                BorderBrush="{DynamicResource HairlineBrush}"
                                BorderThickness="1"
                                BoxShadow="0 14 36 0 #10000000"
                                IsVisible="{Binding ShowStandardBookingCard}">
                            <StackPanel Spacing="12">
                                <TextBlock Text="Buchung"
                                           FontSize="20"
                                           FontWeight="SemiBold"
                                           IsVisible="{Binding ShowBookingTitle}"/>

                                <WrapPanel Orientation="Horizontal" ItemWidth="140">
                                    <Button Name="ClockInButton"
                                            Content="Einstempeln"
                                            Width="140"
                                            Height="36"
                                            Margin="0,0,8,8"
                                            Background="{DynamicResource AccentBrush}"
                                            Foreground="{DynamicResource AccentForegroundBrush}"
                                            BorderThickness="0"
                                            Command="{Binding ClockInCommand}"/>
                                    <Button Name="ClockOutButton"
                                            Content="Ausstempeln"
                                            Width="140"
                                            Height="36"
                                            Margin="0,0,8,8"
                                            Background="{DynamicResource SecondarySurfaceBrush}"
                                            Command="{Binding ClockOutCommand}"/>
                                </WrapPanel>

                                <Border CornerRadius="16"
                                        Padding="12"
                                        Background="{DynamicResource MetricThreeBrush}"
                                        BorderBrush="{DynamicResource HairlineBrush}"
                                        BorderThickness="1"
                                        IsVisible="{Binding ShowClockInSummary}">
                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                                        <StackPanel Grid.Column="0" Spacing="2">
                                            <TextBlock Text="Eingestempelt"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource SubtleTextBrush}"
                                                       FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding ActiveClockInText}"
                                                       FontSize="22"
                                                       FontWeight="Bold"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Spacing="2">
                                            <TextBlock Text="Netto"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource SubtleTextBrush}"
                                                       FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding NetWorkedText}"
                                                       FontSize="22"
                                                       FontWeight="Bold"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10" IsVisible="{Binding ShowDetailedMetrics}">
                                    <Border Grid.Column="0"
                                            CornerRadius="16"
                                            Padding="12"
                                            Background="{DynamicResource MetricOneBrush}"
                                            BorderBrush="{DynamicResource HairlineBrush}"
                                            BorderThickness="1">
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="Brutto"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource SubtleTextBrush}"
                                                       FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding GrossWorkedText}" FontSize="22" FontWeight="Bold"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="1"
                                            CornerRadius="16"
                                            Padding="12"
                                            Background="{DynamicResource MetricTwoBrush}"
                                            BorderBrush="{DynamicResource HairlineBrush}"
                                            BorderThickness="1">
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="Pause (Abzug)"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource SubtleTextBrush}"
                                                       FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding DeductedBreakText}" FontSize="22" FontWeight="Bold"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="2"
                                            CornerRadius="16"
                                            Padding="12"
                                            Background="{DynamicResource MetricThreeBrush}"
                                            BorderBrush="{DynamicResource HairlineBrush}"
                                            BorderThickness="1">
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="Netto"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource SubtleTextBrush}"
                                                       FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding NetWorkedText}" FontSize="22" FontWeight="Bold"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <Border CornerRadius="16"
                                        Padding="12"
                                        Background="{Binding AlertBackground}"
                                        BorderBrush="{DynamicResource HairlineBrush}"
                                        BorderThickness="1"
                                        IsVisible="{Binding ShowAlertPanel}">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="{Binding AlertMessage}"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Foreground="{Binding AlertForeground}"/>
                                        <TextBlock Text="{Binding DesiredEndTimeText}"
                                                   FontSize="13"
                                                   Foreground="{Binding AlertForeground}"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                        <Border CornerRadius="24"
                                Padding="18"
                                Background="{DynamicResource CardMutedBackgroundBrush}"
                                BorderBrush="{DynamicResource HairlineBrush}"
                                BorderThickness="1"
                                BoxShadow="0 12 30 0 #0E000000"
                                IsVisible="{Binding ShowSegmentsSection}">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Arbeitsabschnitte"
                                           FontSize="19"
                                           FontWeight="SemiBold"/>
                                <Grid ColumnDefinitions="*,*,*,Auto"
                                      ColumnSpacing="8"
                                      Margin="0,0,0,4"
                                      IsVisible="{Binding ShowSegmentTableLayout}">
                                    <TextBlock Grid.Column="0" Text="Start" FontWeight="SemiBold" Foreground="{DynamicResource SubtleTextBrush}"/>
                                    <TextBlock Grid.Column="1" Text="Ende" FontWeight="SemiBold" Foreground="{DynamicResource SubtleTextBrush}"/>
                                    <TextBlock Grid.Column="2" Text="Dauer" FontWeight="SemiBold" Foreground="{DynamicResource SubtleTextBrush}"/>
                                    <TextBlock Grid.Column="3" Text="Aktion" FontWeight="SemiBold" Foreground="{DynamicResource SubtleTextBrush}"/>
                                </Grid>
                                <ItemsControl ItemsSource="{Binding Segments}"
                                              IsVisible="{Binding ShowSegmentTableLayout}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:WorkSegmentItemViewModel">
                                            <Border CornerRadius="16"
                                                    Padding="10"
                                                    Margin="0,4,0,0"
                                                    Background="{DynamicResource CardBackgroundBrush}"
                                                    BorderBrush="{DynamicResource HairlineBrush}"
                                                    BorderThickness="1">
                                                <Grid ColumnDefinitions="*,*,*,Auto" ColumnSpacing="8">
                                                    <TextBlock Grid.Column="0"
                                                               VerticalAlignment="Center"
                                                               Text="{Binding Start}"
                                                               IsVisible="{Binding IsNotEditing}"/>
                                                    <TimePicker Grid.Column="0"
                                                                SelectedTime="{Binding EditableStartTime}"
                                                                IsVisible="{Binding IsEditing}"/>

                                                    <TextBlock Grid.Column="1"
                                                               VerticalAlignment="Center"
                                                               Text="{Binding End}"
                                                               IsVisible="{Binding IsNotEditing}"/>
                                                    <TimePicker Grid.Column="1"
                                                                SelectedTime="{Binding EditableEndTime}"
                                                                IsVisible="{Binding IsEditing}"/>

                                                    <TextBlock Grid.Column="2"
                                                               VerticalAlignment="Center"
                                                               Text="{Binding Duration}"/>

                                                    <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="6">
                                                        <Button Content="Bearbeiten"
                                                                IsVisible="{Binding IsNotEditing}"
                                                                Command="{ReflectionBinding DataContext.EditSegmentCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                CommandParameter="{Binding .}"/>
                                                        <Button Content="Uebernehmen"
                                                                IsVisible="{Binding IsEditing}"
                                                                Background="{DynamicResource AccentBrush}"
                                                                Foreground="{DynamicResource AccentForegroundBrush}"
                                                                BorderThickness="0"
                                                                Command="{ReflectionBinding DataContext.ApplySegmentEditCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                CommandParameter="{Binding .}"/>
                                                        <Button Content="Abbrechen"
                                                                IsVisible="{Binding IsEditing}"
                                                                Command="{ReflectionBinding DataContext.CancelSegmentEditCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                CommandParameter="{Binding .}"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <ItemsControl ItemsSource="{Binding Segments}"
                                              IsVisible="{Binding ShowSegmentCardLayout}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:WorkSegmentItemViewModel">
                                            <Border CornerRadius="18"
                                                    Padding="12"
                                                    Margin="0,4,0,0"
                                                    Background="{DynamicResource CardBackgroundBrush}"
                                                    BorderBrush="{DynamicResource HairlineBrush}"
                                                    BorderThickness="1">
                                                <StackPanel Spacing="10">
                                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                                                        <StackPanel Grid.Column="0" Spacing="4">
                                                            <TextBlock Text="Start"
                                                                       FontSize="12"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="{DynamicResource SubtleTextBrush}"/>
                                                            <TextBlock Text="{Binding Start}"
                                                                       FontSize="18"
                                                                       FontWeight="SemiBold"
                                                                       IsVisible="{Binding IsNotEditing}"/>
                                                            <TimePicker SelectedTime="{Binding EditableStartTime}"
                                                                        IsVisible="{Binding IsEditing}"/>
                                                        </StackPanel>

                                                        <StackPanel Grid.Column="1" Spacing="4">
                                                            <TextBlock Text="Ende"
                                                                       FontSize="12"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="{DynamicResource SubtleTextBrush}"/>
                                                            <TextBlock Text="{Binding End}"
                                                                       FontSize="18"
                                                                       FontWeight="SemiBold"
                                                                       IsVisible="{Binding IsNotEditing}"/>
                                                            <TimePicker SelectedTime="{Binding EditableEndTime}"
                                                                        IsVisible="{Binding IsEditing}"/>
                                                        </StackPanel>
                                                    </Grid>

                                                    <Border CornerRadius="14"
                                                            Padding="10"
                                                            Background="{DynamicResource SecondarySurfaceBrush}">
                                                        <StackPanel Spacing="2">
                                                            <TextBlock Text="Dauer"
                                                                       FontSize="12"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="{DynamicResource SubtleTextBrush}"/>
                                                            <TextBlock Text="{Binding Duration}"
                                                                       FontSize="20"
                                                                       FontWeight="Bold"/>
                                                        </StackPanel>
                                                    </Border>

                                                    <WrapPanel Orientation="Horizontal">
                                                        <Button Content="Bearbeiten"
                                                                Margin="0,0,8,8"
                                                                IsVisible="{Binding IsNotEditing}"
                                                                Command="{ReflectionBinding DataContext.EditSegmentCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                CommandParameter="{Binding .}"/>
                                                        <Button Content="Uebernehmen"
                                                                Margin="0,0,8,8"
                                                                IsVisible="{Binding IsEditing}"
                                                                Background="{DynamicResource AccentBrush}"
                                                                Foreground="{DynamicResource AccentForegroundBrush}"
                                                                BorderThickness="0"
                                                                Command="{ReflectionBinding DataContext.ApplySegmentEditCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                CommandParameter="{Binding .}"/>
                                                        <Button Content="Abbrechen"
                                                                Margin="0,0,8,8"
                                                                IsVisible="{Binding IsEditing}"
                                                                Command="{ReflectionBinding DataContext.CancelSegmentEditCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                CommandParameter="{Binding .}"/>
                                                    </WrapPanel>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <TextBlock Text="{Binding SegmentEditMessage}"
                                           Foreground="{DynamicResource SubtleTextBrush}"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Einstellungen" IsVisible="{Binding ShowSettingsTab}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="16" Margin="0,12,0,0">
                        <Border CornerRadius="24"
                                Padding="18"
                                Background="{DynamicResource SettingsCardOneBrush}"
                                BorderBrush="{DynamicResource HairlineBrush}"
                                BorderThickness="1"
                                BoxShadow="0 12 30 0 #0E000000">
                            <StackPanel Spacing="10">
                                <TextBlock Text="Anzeige"
                                           FontSize="20"
                                           FontWeight="SemiBold"/>
                                <TextBlock Text="Theme"/>
                                <ComboBox Name="ThemeComboBox"
                                          ItemsSource="{Binding ThemeModes}"
                                          SelectedItem="{Binding SelectedThemeMode}" />
                            </StackPanel>
                        </Border>

                        <Border CornerRadius="24"
                            Padding="18"
                                Background="{DynamicResource SettingsCardTwoBrush}"
                                BorderBrush="{DynamicResource HairlineBrush}"
                                BorderThickness="1"
                            BoxShadow="0 12 30 0 #0E000000">
                            <StackPanel Spacing="10">
                                <TextBlock Text="Warnstufen"
                                           FontSize="20"
                                           FontWeight="SemiBold"/>
                                <TextBlock Text="Maximale Arbeitszeit Netto (Stunden)"/>
                                <NumericUpDown Minimum="0.1" Maximum="24" Increment="0.25" Value="{Binding MaxWorkHours}"/>

                                <TextBlock Text="Wunscharbeitszeit Netto (Stunden)"/>
                                <NumericUpDown Minimum="0" Maximum="24" Increment="0.25" Value="{Binding DesiredWorkHours}"/>

                                <CheckBox Content="Ausgestempelte Zeiten auf Pausenpflicht anrechnen"
                                          IsChecked="{Binding CountStampedOutTimeAsBreak}"/>

                                <TextBlock Text="Info-Schwelle (Minuten Restzeit)"/>
                                <NumericUpDown Minimum="0" Maximum="600" Increment="5" Value="{Binding InfoThresholdMinutes}"/>

                                <TextBlock Text="Warning-Schwelle (Minuten Restzeit)"/>
                                <NumericUpDown Minimum="0" Maximum="600" Increment="5" Value="{Binding WarningThresholdMinutes}"/>

                                <TextBlock Text="Error-Schwelle (Minuten Restzeit)"/>
                                <NumericUpDown Minimum="0" Maximum="600" Increment="5" Value="{Binding ErrorThresholdMinutes}"/>
                            </StackPanel>
                        </Border>

                        <Border CornerRadius="24"
                            Padding="18"
                            Background="{DynamicResource SettingsCardThreeBrush}"
                            BorderBrush="{DynamicResource HairlineBrush}"
                            BorderThickness="1"
                            BoxShadow="0 12 30 0 #0E000000">
                            <StackPanel Spacing="10">
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0"
                                               Text="Pausenregeln"
                                               FontSize="20"
                                               FontWeight="SemiBold"/>
                                    <Button Grid.Column="1"
                                            Content="+ Regel"
                                            Command="{Binding AddBreakRuleCommand}" />
                                </Grid>

                                <ItemsControl ItemsSource="{Binding BreakRules}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:BreakRuleViewModel">
                                            <Grid ColumnDefinitions="1.1*,1.1*,Auto" ColumnSpacing="8" Margin="0,2,0,2">
                                                <NumericUpDown Grid.Column="0"
                                                               Minimum="0"
                                                               Maximum="24"
                                                               Increment="0.25"
                                                               Value="{Binding MinWorkedHours}"/>
                                                <NumericUpDown Grid.Column="1"
                                                               Minimum="0"
                                                               Maximum="8"
                                                               Increment="0.25"
                                                               Value="{Binding DeductedBreakHours}"/>
                                                <Button Grid.Column="2"
                                                        Content="Entfernen"
                                                        Command="{ReflectionBinding DataContext.RemoveBreakRuleCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding .}"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock Text="Format: Wenn Arbeitszeit >= MinWorkedHours, dann DeductedBreakHours abziehen."
                                           FontSize="12"
                                           Foreground="{DynamicResource SubtleTextBrush}"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <Button Content="Einstellungen jetzt speichern"
                                HorizontalAlignment="Right"
                                Command="{Binding SaveSettingsCommand}"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
    </ScrollViewer>

</Window>
