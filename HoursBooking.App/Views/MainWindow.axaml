<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:HoursBooking.App.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d" d:DesignWidth="1180" d:DesignHeight="760"
        x:Class="HoursBooking.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/hoursbooking-icon-dark.ico"
    Title="{Binding WindowTitle}"
    Background="{DynamicResource WindowBackgroundBrush}"
    Foreground="{DynamicResource WindowForegroundBrush}">

    <Design.DataContext>
        <!-- This only sets the DataContext for the previewer in an IDE,
             to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">
        <Grid RowDefinitions="Auto,*" RowSpacing="8" Margin="16">
        <Border Grid.Row="0"
                CornerRadius="18"
                Padding="14"
                Margin="0,0,0,12"
            Background="{DynamicResource HeaderBackgroundBrush}"
                BorderBrush="{DynamicResource HairlineBrush}"
                BorderThickness="1"
                BoxShadow="0 10 24 0 #10000000"
                IsVisible="{Binding ShowWindowHeader}">
            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" RowSpacing="8">
                <TextBlock Grid.Row="0"
                           Grid.Column="0"
                           Text="{Binding HeaderTitle}"
                           FontSize="24"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource HeaderForegroundBrush}"/>
                <TextBlock Grid.Row="1"
                           Grid.Column="0"
                           Text="{Binding CurrentDayLabel}"
                           IsVisible="{Binding ShowHeaderDate}"
                           FontSize="15"
                           Foreground="{DynamicResource HeaderSecondaryForegroundBrush}"/>

                <Border Grid.Row="0"
                        Grid.RowSpan="2"
                        Grid.Column="1"
                        IsVisible="{Binding ShowHeaderClock}"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Padding="12,8"
                        CornerRadius="14"
                        Background="{DynamicResource SecondarySurfaceBrush}"
                        BorderBrush="{DynamicResource HairlineBrush}"
                        BorderThickness="1">
                    <TextBlock Text="{Binding CurrentTimeLabel}"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="{DynamicResource HeaderForegroundBrush}"/>
                </Border>
            </Grid>
        </Border>

        <TabControl x:Name="MainTabs" Grid.Row="1">
            <TabItem Header="{Binding BookingTabHeader}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="14" Margin="0,10,0,0">
                        <Border CornerRadius="22"
                                Padding="12"
                                Background="{DynamicResource CardBackgroundBrush}"
                                BorderBrush="{DynamicResource HairlineBrush}"
                                BorderThickness="1"
                                BoxShadow="0 10 24 0 #12000000"
                                IsVisible="{Binding ShowMinimalClockMode}">
                            <StackPanel Spacing="10">
                                <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                                    <Border Grid.Column="0"
                                            CornerRadius="14"
                                            Padding="10"
                                            Background="{DynamicResource SecondarySurfaceBrush}"
                                            BorderBrush="{DynamicResource HairlineBrush}"
                                            BorderThickness="1">
                                        <StackPanel Spacing="2" VerticalAlignment="Center">
                                            <TextBlock Text="{ReflectionBinding DataContext.CompactStartLabel, RelativeSource={RelativeSource AncestorType=Window}}"
                                                       FontSize="10"
                                                       Foreground="{DynamicResource SubtleTextBrush}"/>
                                            <TextBlock Text="{Binding ActiveClockInText}"
                                                       FontSize="20"
                                                       FontWeight="SemiBold"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="1"
                                            CornerRadius="14"
                                            Padding="10"
                                            Background="{DynamicResource MetricThreeBrush}"
                                            BorderBrush="{DynamicResource HairlineBrush}"
                                            BorderThickness="1">
                                        <StackPanel Spacing="2" VerticalAlignment="Center">
                                            <TextBlock Text="{ReflectionBinding DataContext.CompactNetLabel, RelativeSource={RelativeSource AncestorType=Window}}"
                                                       FontSize="10"
                                                       Foreground="{DynamicResource SubtleTextBrush}"/>
                                            <TextBlock Text="{Binding NetWorkedText}"
                                                       FontSize="20"
                                                       FontWeight="Bold"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <Grid ColumnDefinitions="Auto,Auto"
                                      ColumnSpacing="10"
                                      HorizontalAlignment="Center">
                                    <Button Width="52"
                                            Classes="iconRound primaryAction"
                                            Grid.Column="0"
                                            ToolTip.Tip="{Binding ClockInText}"
                                            Command="{Binding ClockInCommand}">
                                        <PathIcon Data="M 5 3 L 19 12 L 5 21 Z"
                                                  Width="18"
                                                  Height="18"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                                    </Button>

                                    <Button Width="52"
                                            Classes="iconRound secondaryAction"
                                            Grid.Column="1"
                                            ToolTip.Tip="{Binding ClockOutText}"
                                            Command="{Binding ClockOutCommand}">
                                        <PathIcon Data="M 5 5 H 19 V 19 H 5 Z"
                                                  Width="16"
                                                  Height="16"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                                    </Button>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border CornerRadius="24"
                                Padding="18"
                                Background="{DynamicResource CardBackgroundBrush}"
                                BorderBrush="{DynamicResource HairlineBrush}"
                                BorderThickness="1"
                                BoxShadow="0 14 36 0 #10000000"
                                IsVisible="{Binding ShowStandardBookingCard}">
                            <StackPanel Spacing="12">
                                <TextBlock Text="{Binding ClockSectionTitle}"
                                           FontSize="20"
                                           FontWeight="SemiBold"
                                           IsVisible="{Binding ShowBookingTitle}"/>

                                <WrapPanel Orientation="Horizontal" ItemWidth="168">
                                    <Button Name="ClockInButton"
                                            Width="160"
                                            Height="36"
                                            Margin="0,0,8,8"
                                            Classes="primaryAction"
                                            Command="{Binding ClockInCommand}">
                                        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                                            <PathIcon Data="M 5 3 L 19 12 L 5 21 Z" Width="14" Height="14"/>
                                            <TextBlock Text="{ReflectionBinding DataContext.ClockInText, RelativeSource={RelativeSource AncestorType=Window}}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Name="ClockOutButton"
                                            Width="160"
                                            Height="36"
                                            Margin="0,0,8,8"
                                            Classes="secondaryAction"
                                            Command="{Binding ClockOutCommand}">
                                        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                                            <PathIcon Data="M 5 5 H 19 V 19 H 5 Z" Width="13" Height="13"/>
                                            <TextBlock Text="{ReflectionBinding DataContext.ClockOutText, RelativeSource={RelativeSource AncestorType=Window}}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </WrapPanel>

                                <Border CornerRadius="16"
                                        Padding="12"
                                        Background="{DynamicResource MetricThreeBrush}"
                                        BorderBrush="{DynamicResource HairlineBrush}"
                                        BorderThickness="1"
                                        IsVisible="{Binding ShowClockInSummary}">
                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                                        <StackPanel Grid.Column="0" Spacing="2">
                                            <TextBlock Text="{Binding SummaryClockedInLabel}"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource SubtleTextBrush}"
                                                       FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding ActiveClockInText}"
                                                       FontSize="22"
                                                       FontWeight="Bold"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Spacing="2">
                                            <TextBlock Text="{Binding SummaryNetLabel}"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource SubtleTextBrush}"
                                                       FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding NetWorkedText}"
                                                       FontSize="22"
                                                       FontWeight="Bold"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10" IsVisible="{Binding ShowDetailedMetrics}">
                                    <Border Grid.Column="0"
                                            CornerRadius="16"
                                            Padding="12"
                                            Background="{DynamicResource MetricOneBrush}"
                                            BorderBrush="{DynamicResource HairlineBrush}"
                                            BorderThickness="1">
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="{Binding GrossLabel}"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource SubtleTextBrush}"
                                                       FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding GrossWorkedText}" FontSize="22" FontWeight="Bold"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="1"
                                            CornerRadius="16"
                                            Padding="12"
                                            Background="{DynamicResource MetricTwoBrush}"
                                            BorderBrush="{DynamicResource HairlineBrush}"
                                            BorderThickness="1">
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="{Binding BreakDeductionLabel}"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource SubtleTextBrush}"
                                                       FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding DeductedBreakText}" FontSize="22" FontWeight="Bold"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="2"
                                            CornerRadius="16"
                                            Padding="12"
                                            Background="{DynamicResource MetricThreeBrush}"
                                            BorderBrush="{DynamicResource HairlineBrush}"
                                            BorderThickness="1">
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="{Binding NetLabel}"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource SubtleTextBrush}"
                                                       FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding NetWorkedText}" FontSize="22" FontWeight="Bold"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <Border CornerRadius="16"
                                        Padding="12"
                                        Background="{Binding AlertBackground}"
                                        BorderBrush="{DynamicResource HairlineBrush}"
                                        BorderThickness="1"
                                        IsVisible="{Binding ShowAlertPanel}">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="{Binding AlertMessage}"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Foreground="{Binding AlertForeground}"/>
                                        <TextBlock Text="{Binding DesiredEndTimeText}"
                                                   FontSize="13"
                                                   Foreground="{Binding AlertForeground}"/>
                                    </StackPanel>
                                </Border>

                                <Border CornerRadius="20"
                                        Padding="16"
                                        Background="{DynamicResource CardBackgroundBrush}"
                                        BorderBrush="{DynamicResource HairlineBrush}"
                                        BorderThickness="1"
                                        BoxShadow="0 10 24 0 #12000000">
                                    <StackPanel Spacing="12">
                                        <TextBlock Text="{Binding WeeklyMetricsTitle}"
                                                   FontSize="16"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource WindowForegroundBrush}"/>
                                        <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="10">
                                            <Border Grid.Column="0"
                                                    CornerRadius="14"
                                                    Padding="10"
                                                    Background="{DynamicResource MetricOneBrush}"
                                                    BorderBrush="{DynamicResource HairlineBrush}"
                                                    BorderThickness="1">
                                                <StackPanel Spacing="2">
                                                    <TextBlock Text="{Binding WeeklyGrossLabel}"
                                                               FontSize="11"
                                                               Foreground="{DynamicResource SubtleTextBrush}"
                                                               FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding WeeklyGrossWorkedText}"
                                                               FontSize="18"
                                                               FontWeight="Bold"/>
                                                </StackPanel>
                                            </Border>

                                            <Border Grid.Column="1"
                                                    CornerRadius="14"
                                                    Padding="10"
                                                    Background="{DynamicResource MetricThreeBrush}"
                                                    BorderBrush="{DynamicResource HairlineBrush}"
                                                    BorderThickness="1">
                                                <StackPanel Spacing="2">
                                                    <TextBlock Text="{Binding WeeklyNetLabel}"
                                                               FontSize="11"
                                                               Foreground="{DynamicResource SubtleTextBrush}"
                                                               FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding WeeklyNetWorkedText}"
                                                               FontSize="18"
                                                               FontWeight="Bold"/>
                                                </StackPanel>
                                            </Border>

                                            <Border Grid.Column="2"
                                                    CornerRadius="14"
                                                    Padding="10"
                                                    Background="{DynamicResource MetricTwoBrush}"
                                                    BorderBrush="{DynamicResource HairlineBrush}"
                                                    BorderThickness="1">
                                                <StackPanel Spacing="2">
                                                    <TextBlock Text="{Binding WeeklyDesiredLabel}"
                                                               FontSize="11"
                                                               Foreground="{DynamicResource SubtleTextBrush}"
                                                               FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding WeeklyDesiredText}"
                                                               FontSize="18"
                                                               FontWeight="Bold"/>
                                                </StackPanel>
                                            </Border>

                                            <Border Grid.Column="3"
                                                    CornerRadius="14"
                                                    Padding="10"
                                                    Background="{DynamicResource CardBackgroundBrush}"
                                                    BorderBrush="{DynamicResource HairlineBrush}"
                                                    BorderThickness="1">
                                                <StackPanel Spacing="2">
                                                    <TextBlock Text="{Binding WeeklyDifferenceLabel}"
                                                               FontSize="11"
                                                               Foreground="{DynamicResource SubtleTextBrush}"
                                                               FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding WeeklyDifferenceStatus}"
                                                               FontSize="18"
                                                               FontWeight="Bold"/>
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                        <Border CornerRadius="24"
                                Padding="18"
                                Background="{DynamicResource CardMutedBackgroundBrush}"
                                BorderBrush="{DynamicResource HairlineBrush}"
                                BorderThickness="1"
                                BoxShadow="0 12 30 0 #0E000000"
                                IsVisible="{Binding ShowSegmentsSection}">
                            <StackPanel Spacing="8">
                                <TextBlock Text="{Binding WorkSegmentsTitle}"
                                           FontSize="19"
                                           FontWeight="SemiBold"/>

                                <Grid ColumnDefinitions="*,Auto,Auto"
                                      ColumnSpacing="8"
                                      Margin="0,0,0,2">
                                    <TextBox Grid.Column="0"
                                             Watermark="{Binding PendingCommentHint}"
                                             MaxLength="280"
                                             Text="{Binding PendingComment}"/>
                                    <Button Grid.Column="1"
                                            Content="{Binding ExportSegmentsText}"
                                            Classes="secondaryAction"
                                            Command="{Binding ExportSegmentsCommand}"/>
                                    <Button Grid.Column="2"
                                            Content="{Binding ClearSegmentsText}"
                                            Classes="ghostAction"
                                            Command="{Binding ClearAllSegmentsCommand}"/>
                                </Grid>
                                <TextBlock Text="{Binding PendingCommentLabel}"
                                           Foreground="{DynamicResource SubtleTextBrush}"
                                           FontSize="12"/>

                                <Grid ColumnDefinitions="*,*,*,1.6*,Auto"
                                      ColumnSpacing="8"
                                      Margin="0,0,0,4"
                                      IsVisible="{Binding ShowSegmentTableLayout}">
                                    <TextBlock Grid.Column="0" Text="{Binding StartLabel}" FontWeight="SemiBold" Foreground="{DynamicResource SubtleTextBrush}"/>
                                    <TextBlock Grid.Column="1" Text="{Binding EndLabel}" FontWeight="SemiBold" Foreground="{DynamicResource SubtleTextBrush}"/>
                                    <TextBlock Grid.Column="2" Text="{Binding DurationLabel}" FontWeight="SemiBold" Foreground="{DynamicResource SubtleTextBrush}"/>
                                    <TextBlock Grid.Column="3" Text="{Binding CommentLabel}" FontWeight="SemiBold" Foreground="{DynamicResource SubtleTextBrush}"/>
                                    <TextBlock Grid.Column="4" Text="{Binding ActionLabel}" FontWeight="SemiBold" Foreground="{DynamicResource SubtleTextBrush}"/>
                                </Grid>
                                <ItemsControl ItemsSource="{Binding Segments}"
                                              IsVisible="{Binding ShowSegmentTableLayout}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:WorkSegmentItemViewModel">
                                            <Border CornerRadius="16"
                                                    Padding="10"
                                                    Margin="0,4,0,0"
                                                    Background="{DynamicResource CardBackgroundBrush}"
                                                    BorderBrush="{DynamicResource HairlineBrush}"
                                                    BorderThickness="1">
                                                <Grid ColumnDefinitions="*,*,*,1.6*,Auto" ColumnSpacing="8">
                                                    <TextBlock Grid.Column="0"
                                                               VerticalAlignment="Center"
                                                               Text="{Binding Start}"
                                                               IsVisible="{Binding IsNotEditing}"/>
                                                    <TimePicker Grid.Column="0"
                                                                SelectedTime="{Binding EditableStartTime}"
                                                                IsVisible="{Binding IsEditing}"/>

                                                    <TextBlock Grid.Column="1"
                                                               VerticalAlignment="Center"
                                                               Text="{Binding End}"
                                                               IsVisible="{Binding IsNotEditing}"/>
                                                    <TimePicker Grid.Column="1"
                                                                SelectedTime="{Binding EditableEndTime}"
                                                                IsVisible="{Binding IsEditing}"/>

                                                    <TextBlock Grid.Column="2"
                                                               VerticalAlignment="Center"
                                                               Text="{Binding Duration}"/>

                                                    <TextBlock Grid.Column="3"
                                                               VerticalAlignment="Center"
                                                               Text="{Binding Comment}"
                                                               TextWrapping="Wrap"
                                                               IsVisible="{Binding IsNotEditing}"/>
                                                    <TextBox Grid.Column="3"
                                                             Text="{Binding EditableComment}"
                                                             MaxLength="280"
                                                             IsVisible="{Binding IsEditing}"/>

                                                    <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="6">
                                                        <Button Content="{ReflectionBinding DataContext.EditText, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            Classes="secondaryAction"
                                                                IsVisible="{Binding IsNotEditing}"
                                                                Command="{ReflectionBinding DataContext.EditSegmentCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                CommandParameter="{Binding .}"/>
                                                        <Button Content="{ReflectionBinding DataContext.ApplyText, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            Classes="primaryAction"
                                                                IsVisible="{Binding IsEditing}"
                                                                Command="{ReflectionBinding DataContext.ApplySegmentEditCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                CommandParameter="{Binding .}"/>
                                                        <Button Content="{ReflectionBinding DataContext.CancelText, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            Classes="ghostAction"
                                                                IsVisible="{Binding IsEditing}"
                                                                Command="{ReflectionBinding DataContext.CancelSegmentEditCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                CommandParameter="{Binding .}"/>
                                                        <Button Content="{ReflectionBinding DataContext.RemoveText, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            Classes="ghostAction"
                                                                IsVisible="{Binding IsNotEditing}"
                                                                Command="{ReflectionBinding DataContext.RemoveSegmentCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                CommandParameter="{Binding .}"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <ItemsControl ItemsSource="{Binding Segments}"
                                              IsVisible="{Binding ShowSegmentCardLayout}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:WorkSegmentItemViewModel">
                                            <Border CornerRadius="18"
                                                    Padding="12"
                                                    Margin="0,4,0,0"
                                                    Background="{DynamicResource CardBackgroundBrush}"
                                                    BorderBrush="{DynamicResource HairlineBrush}"
                                                    BorderThickness="1">
                                                <StackPanel Spacing="10">
                                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                                                        <StackPanel Grid.Column="0" Spacing="4">
                                                            <TextBlock Text="{ReflectionBinding DataContext.StartLabel, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                       FontSize="12"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="{DynamicResource SubtleTextBrush}"/>
                                                            <TextBlock Text="{Binding Start}"
                                                                       FontSize="18"
                                                                       FontWeight="SemiBold"
                                                                       IsVisible="{Binding IsNotEditing}"/>
                                                            <TimePicker SelectedTime="{Binding EditableStartTime}"
                                                                        IsVisible="{Binding IsEditing}"/>
                                                        </StackPanel>

                                                        <StackPanel Grid.Column="1" Spacing="4">
                                                            <TextBlock Text="{ReflectionBinding DataContext.EndLabel, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                       FontSize="12"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="{DynamicResource SubtleTextBrush}"/>
                                                            <TextBlock Text="{Binding End}"
                                                                       FontSize="18"
                                                                       FontWeight="SemiBold"
                                                                       IsVisible="{Binding IsNotEditing}"/>
                                                            <TimePicker SelectedTime="{Binding EditableEndTime}"
                                                                        IsVisible="{Binding IsEditing}"/>
                                                        </StackPanel>
                                                    </Grid>

                                                    <Border CornerRadius="14"
                                                            Padding="10"
                                                            Background="{DynamicResource SecondarySurfaceBrush}">
                                                        <StackPanel Spacing="2">
                                                            <TextBlock Text="{ReflectionBinding DataContext.CardDurationLabel, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                       FontSize="12"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="{DynamicResource SubtleTextBrush}"/>
                                                            <TextBlock Text="{Binding Duration}"
                                                                       FontSize="20"
                                                                       FontWeight="Bold"/>
                                                        </StackPanel>
                                                    </Border>

                                                    <StackPanel Spacing="4">
                                                        <TextBlock Text="{ReflectionBinding DataContext.CommentLabel, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                   FontSize="12"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{DynamicResource SubtleTextBrush}"/>
                                                        <TextBlock Text="{Binding Comment}"
                                                                   TextWrapping="Wrap"
                                                                   IsVisible="{Binding IsNotEditing}"/>
                                                        <TextBox Text="{Binding EditableComment}"
                                                                 MaxLength="280"
                                                                 IsVisible="{Binding IsEditing}"/>
                                                    </StackPanel>

                                                    <WrapPanel Orientation="Horizontal">
                                                        <Button Content="{ReflectionBinding DataContext.EditText, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            Classes="secondaryAction"
                                                                Margin="0,0,8,8"
                                                                IsVisible="{Binding IsNotEditing}"
                                                                Command="{ReflectionBinding DataContext.EditSegmentCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                CommandParameter="{Binding .}"/>
                                                        <Button Content="{ReflectionBinding DataContext.ApplyText, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            Classes="primaryAction"
                                                                Margin="0,0,8,8"
                                                                IsVisible="{Binding IsEditing}"
                                                                Command="{ReflectionBinding DataContext.ApplySegmentEditCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                CommandParameter="{Binding .}"/>
                                                        <Button Content="{ReflectionBinding DataContext.CancelText, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            Classes="ghostAction"
                                                                Margin="0,0,8,8"
                                                                IsVisible="{Binding IsEditing}"
                                                                Command="{ReflectionBinding DataContext.CancelSegmentEditCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                CommandParameter="{Binding .}"/>
                                                        <Button Content="{ReflectionBinding DataContext.RemoveText, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            Classes="ghostAction"
                                                                Margin="0,0,8,8"
                                                                IsVisible="{Binding IsNotEditing}"
                                                                Command="{ReflectionBinding DataContext.RemoveSegmentCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                CommandParameter="{Binding .}"/>
                                                    </WrapPanel>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <TextBlock Text="{Binding SegmentEditMessage}"
                                           Foreground="{DynamicResource SubtleTextBrush}"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="{Binding SettingsTabHeader}" IsVisible="{Binding ShowSettingsTab}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="16" Margin="0,12,0,0">
                        <Border CornerRadius="24"
                                Padding="18"
                                Background="{DynamicResource SettingsCardOneBrush}"
                                BorderBrush="{DynamicResource HairlineBrush}"
                                BorderThickness="1"
                                BoxShadow="0 12 30 0 #0E000000">
                            <StackPanel Spacing="10">
                                <TextBlock Text="{Binding DisplaySettingsTitle}"
                                           FontSize="20"
                                           FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding ThemeLabel}"/>
                                <ComboBox Name="ThemeComboBox"
                                          ItemsSource="{Binding ThemeOptions}"
                                          SelectedItem="{Binding SelectedThemeOption}" />

                                <TextBlock Text="{Binding LanguageLabel}"/>
                                <ComboBox ItemsSource="{Binding LanguageOptions}"
                                          SelectedItem="{Binding SelectedLanguageOption}" />

                                <CheckBox Content="{Binding MinimizeToTrayOnCloseLabel}"
                                          IsChecked="{Binding MinimizeToTrayOnClose}"/>
                                <TextBlock Text="{Binding TraySupportHintText}"
                                           FontSize="12"
                                           Foreground="{DynamicResource SubtleTextBrush}"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <Border CornerRadius="24"
                            Padding="18"
                                Background="{DynamicResource SettingsCardTwoBrush}"
                                BorderBrush="{DynamicResource HairlineBrush}"
                                BorderThickness="1"
                            BoxShadow="0 12 30 0 #0E000000">
                            <StackPanel Spacing="10">
                                <TextBlock Text="{Binding AlertLevelsTitle}"
                                           FontSize="20"
                                           FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding MaxWorkHoursLabel}"/>
                                <NumericUpDown Minimum="0.1" Maximum="24" Increment="0.25" Value="{Binding MaxWorkHours}"/>

                                <TextBlock Text="{Binding DesiredWorkHoursLabel}"/>
                                <NumericUpDown Minimum="0" Maximum="24" Increment="0.25" Value="{Binding DesiredWorkHours}"/>

                                <TextBlock Text="{Binding WeeklyDesiredHoursLabel}"/>
                                <NumericUpDown Minimum="0" Maximum="168" Increment="0.25" Value="{Binding WeeklyDesiredHours}"/>

                                <CheckBox Content="{Binding CountStampedOutBreakLabel}"
                                          IsChecked="{Binding CountStampedOutTimeAsBreak}"/>

                                <TextBlock Text="{Binding InfoThresholdLabel}"/>
                                <NumericUpDown Minimum="0" Maximum="600" Increment="5" Value="{Binding InfoThresholdMinutes}"/>

                                <TextBlock Text="{Binding WarningThresholdLabel}"/>
                                <NumericUpDown Minimum="0" Maximum="600" Increment="5" Value="{Binding WarningThresholdMinutes}"/>

                                <TextBlock Text="{Binding ErrorThresholdLabel}"/>
                                <NumericUpDown Minimum="0" Maximum="600" Increment="5" Value="{Binding ErrorThresholdMinutes}"/>
                            </StackPanel>
                        </Border>

                        <Border CornerRadius="24"
                            Padding="18"
                            Background="{DynamicResource SettingsCardThreeBrush}"
                            BorderBrush="{DynamicResource HairlineBrush}"
                            BorderThickness="1"
                            BoxShadow="0 12 30 0 #0E000000">
                            <StackPanel Spacing="10">
                                <Grid ColumnDefinitions="*,Auto">
                                        <TextBlock Grid.Column="0"
                                               Text="{Binding BreakRulesTitle}"
                                               FontSize="20"
                                               FontWeight="SemiBold"/>
                                    <Button Grid.Column="1"
                                            Content="{Binding AddRuleText}"
                                            Classes="secondaryAction"
                                            Command="{Binding AddBreakRuleCommand}" />
                                </Grid>

                                <ItemsControl ItemsSource="{Binding BreakRules}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:BreakRuleViewModel">
                                            <Grid ColumnDefinitions="1.1*,1.1*,Auto" ColumnSpacing="8" Margin="0,2,0,2">
                                                <NumericUpDown Grid.Column="0"
                                                               Minimum="0"
                                                               Maximum="24"
                                                               Increment="0.25"
                                                               Value="{Binding MinWorkedHours}"/>
                                                <NumericUpDown Grid.Column="1"
                                                               Minimum="0"
                                                               Maximum="8"
                                                               Increment="0.25"
                                                               Value="{Binding DeductedBreakHours}"/>
                                                <Button Grid.Column="2"
                                                        Content="{ReflectionBinding DataContext.RemoveText, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    Classes="ghostAction"
                                                        Command="{ReflectionBinding DataContext.RemoveBreakRuleCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding .}"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock Text="{Binding BreakRulesFormatText}"
                                           FontSize="12"
                                           Foreground="{DynamicResource SubtleTextBrush}"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <Button Content="{Binding SaveSettingsText}"
                            Classes="primaryAction"
                                HorizontalAlignment="Right"
                                Command="{Binding SaveSettingsCommand}"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
    </ScrollViewer>

</Window>
